{
  "review_gates": {
    "gate_1_requirements": {
      "enabled": true,
      "required": true,
      "timeout_minutes": 30,
      "description": "需求文档审查"
    },
    "gate_2_solution": {
      "enabled": true,
      "required": true,
      "timeout_minutes": 20,
      "description": "技术方案审查"
    },
    "gate_3_plan": {
      "enabled": true,
      "required": false,
      "timeout_minutes": 15,
      "description": "实现计划 + 测试计划框架审查"
    },
    "gate_4_tdd_test_cases": {
      "enabled": true,
      "required": true,
      "timeout_minutes": 15,
      "description": "TDD 测试用例设计审查"
    },
    "gate_5_test_code": {
      "enabled": true,
      "required": true,
      "timeout_minutes": 15,
      "description": "测试代码 + RED阶段验证审查"
    },
    "gate_6_implementation": {
      "enabled": true,
      "required": true,
      "timeout_minutes": 15,
      "description": "实现代码 + GREEN阶段验证 + AI评审"
    },
    "gate_7_acceptance": {
      "enabled": true,
      "required": true,
      "timeout_minutes": 10,
      "description": "完整测试 + 最终验收"
    }
  },
  "quick_fix_mode": {
    "skip_gates": [
      "gate_2_solution",
      "gate_3_plan",
      "gate_4_tdd_test_cases",
      "gate_5_test_code"
    ],
    "description": "快速修复模式跳过的审查节点（直接进入实现代码生成）"
  },
  "tdd_mode": {
    "enabled": true,
    "red_green_verification": true,
    "description": "TDD 模式：测试用例设计 → 测试代码(RED) → 实现代码(GREEN)"
  },
  "test_limits": {
    "p0_max": 10,
    "p1_max": 20,
    "p2_max": 10,
    "total_max": 40,
    "description": "各级测试用例数量上限"
  }
}
